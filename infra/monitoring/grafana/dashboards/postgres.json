{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Active Connections by Database",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "{{datname}} — active"
        }
      ]
    },
    {
      "title": "Total Connections by Database",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Transactions Committed (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Transactions Rolled Back (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Rows Fetched / Returned (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}} fetched"
        },
        {
          "expr": "rate(pg_stat_database_tup_returned{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}} returned"
        }
      ]
    },
    {
      "title": "Rows Inserted / Updated / Deleted (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}} inserted"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}} updated"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname!=\"\"}[1m])",
          "legendFormat": "{{datname}} deleted"
        }
      ]
    },
    {
      "title": "Locks by Mode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_locks_count",
          "legendFormat": "{{datname}} — {{mode}}"
        }
      ]
    },
    {
      "title": "Database Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes",
          "legendFormat": "{{datname}}"
        }
      ]
    },
    {
      "title": "Replication Lag (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_replication_lag",
          "legendFormat": "replication lag"
        }
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.9, "color": "yellow" },
              { "value": 0.95, "color": "green" }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname!=\"\"} / (pg_stat_database_blks_hit{datname!=\"\"} + pg_stat_database_blks_read{datname!=\"\"} + 1)",
          "legendFormat": "{{datname}}"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["postgres", "database"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "title": "PostgreSQL",
  "uid": "postgres-overview"
}
