{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{instance}} — {{id}}"
        }
      ]
    },
    {
      "title": "JVM Heap Committed vs Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 5 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_committed_bytes{area=\"heap\"}",
          "legendFormat": "{{instance}} committed"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{instance}} max"
        }
      ]
    },
    {
      "title": "JVM Non-Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\"}",
          "legendFormat": "{{instance}} — {{id}}"
        }
      ]
    },
    {
      "title": "GC Pause Time (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum[1m])",
          "legendFormat": "{{instance}} — {{cause}}"
        }
      ]
    },
    {
      "title": "JVM Threads — Live",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "JVM Threads — States",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_states_threads",
          "legendFormat": "{{instance}} — {{state}}"
        }
      ]
    },
    {
      "title": "HTTP Request Rate (per service)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "HTTP Request Latency P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (instance, le) (rate(http_server_requests_seconds_bucket[1m])))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "{{instance}} — {{pool}}"
        },
        {
          "expr": "hikaricp_connections_max",
          "legendFormat": "{{instance}} — max"
        }
      ]
    },
    {
      "title": "HikariCP Connection Pending",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "{{instance}} — {{pool}}"
        }
      ]
    },
    {
      "title": "Tomcat Threads — Busy vs Max",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads",
          "legendFormat": "{{instance}} busy"
        },
        {
          "expr": "tomcat_threads_config_max_threads",
          "legendFormat": "{{instance}} max"
        }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "HTTP 5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "HTTP 5xx Error Rate % (of total requests)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) / sum by (instance) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "HTTP 5xx by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (instance, uri, status) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) > 0",
          "legendFormat": "{{instance}} {{uri}} [{{status}}]"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["jvm", "spring-boot"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
